# Hermes Homelab — Secrets Template
# Copy this file to config/secrets.env and fill in your values.
# config/secrets.env is gitignored and should never be committed.

# OpenRouter API key — used as cloud fallback when local models aren't sufficient.
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Anthropic API key — optional, for direct Claude API access.
# Note: requires a pay-as-you-go API key from https://console.anthropic.com/
# Subscription tokens do not work with third-party tools.
ANTHROPIC_API_KEY=
